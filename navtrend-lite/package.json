{
  "name": "marketnews-mobile",
  "main": "expo-router/entry",
  "version": "2.0.0",
  "scripts": {
    "start": "expo start",
    "start:clean": "./scripts/clean-start.sh",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "prebuild": "expo prebuild --clean",
    "build": "./scripts/build.sh",
    "build:android": "./scripts/build.sh -p android",
    "build:ios": "./scripts/build.sh -p ios",
    "build:clean": "./scripts/build.sh -c",
    "build:production:android": "eas build --platform android --local --profile production",
    "build:production:ios": "EXPO_NO_CAPABILITY_SYNC=1 eas build --platform ios --local --profile production",
    "setup": "./scripts/setup.sh",
    "setup:env": "./scripts/setup.sh -e",
    "setup:check": "./scripts/setup.sh -c",
    "fix-login": "./scripts/fix-login.sh",
    "fix-login:check": "./scripts/fix-login.sh -c",
    "fix-login:auto": "./scripts/fix-login.sh -f",
    "monitor": "./scripts/monitor.sh",
    "monitor:network": "./scripts/monitor.sh -n",
    "monitor:build": "./scripts/monitor.sh -b",
    "monitor:test": "./scripts/monitor.sh -t",
    "monitor:watch": "./scripts/monitor.sh -w"
  },
  "dependencies": {
    "@clerk/clerk-expo": "^2.13.0",
    "@expo/vector-icons": "^15.0.3",
    "@gorhom/bottom-sheet": "^5.2.6",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/slider": "5.0.1",
    "@react-navigation/bottom-tabs": "^7.3.10",
    "@react-navigation/elements": "^2.3.8",
    "@react-navigation/native": "^7.1.6",
    "crypto-js": "^4.2.0",
    "dayjs": "^1.11.18",
    "expo": "~54.0.0",
    "expo-application": "~7.0.7",
    "expo-auth-session": "~7.0.8",
    "expo-blur": "~15.0.7",
    "expo-build-properties": "~1.0.9",
    "expo-cellular": "~8.0.7",
    "expo-constants": "~18.0.10",
    "expo-crypto": "~15.0.7",
    "expo-dev-client": "~6.0.17",
    "expo-device": "~8.0.9",
    "expo-file-system": "~19.0.17",
    "expo-font": "~14.0.9",
    "expo-haptics": "~15.0.7",
    "expo-image": "~3.0.10",
    "expo-insights": "~0.10.7",
    "expo-linear-gradient": "~15.0.7",
    "expo-linking": "~8.0.8",
    "expo-localization": "~17.0.7",
    "expo-navigation-bar": "~5.0.9",
    "expo-network": "~8.0.7",
    "expo-router": "~6.0.14",
    "expo-screen-orientation": "~9.0.7",
    "expo-secure-store": "~15.0.7",
    "expo-splash-screen": "~31.0.10",
    "expo-symbols": "~1.0.7",
    "expo-system-ui": "~6.0.8",
    "expo-tracking-transparency": "~6.0.7",
    "expo-web-browser": "~15.0.9",
    "posthog-react-native": "^4.11.0",
    "posthog-react-native-session-replay": "^1.2.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-draggable-flatlist": "^4.0.3",
    "react-native-dropdown-picker": "^5.4.6",
    "react-native-edge-to-edge": "1.6.0",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-keyboard-controller": "1.18.5",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-shimmer-placeholder": "^2.0.9",
    "react-native-sortables": "^1.9.2",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.0",
    "react-native-webview": "13.15.0",
    "react-native-worklets": "0.5.1",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/crypto-js": "^4.2.2",
    "@types/react": "~19.1.10",
    "babel-plugin-module-resolver": "^5.0.2",
    "dotenv": "^17.2.3",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~10.0.0",
    "eslint-import-resolver-babel-module": "^5.3.2",
    "eslint-import-resolver-typescript": "^4.4.4",
    "sharp": "^0.34.2",
    "typescript": "~5.9.2"
  },
  "private": true,
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "posthog-react-native-session-replay",
          "crypto-js",
          "react-native-dropdown-picker"
        ]
      }
    },
    "install": {
      "exclude": []
    }
  }
}
