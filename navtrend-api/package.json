{
  "name": "navtrend-api",
  "version": "1.0.0",
  "description": "NavTrend Backend API - Stock market data API built on Cloudflare Workers",
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev --ip 0.0.0.0 --port 8787 --local --persist-to .wrangler/state",
    "deploy": "wrangler deploy --minify",
    "deploy:dev": "wrangler deploy --env dev",
    "deploy:prod": "wrangler deploy --env production",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 execute navtrend-db-local --local --file=$(ls -t drizzle/*.sql | head -1)",
    "db:rebuild:local": "rm -rf drizzle/*.sql drizzle/meta && npm run db:generate && rm -rf .wrangler/state/v3/d1 && npm run db:migrate:local",
    "db:import:local": "bash scripts/migrate-data/03-import-d1-local.sh",
    "db:init:local": "npm run db:rebuild:local && npm run db:import:local",
    "db:studio": "drizzle-kit studio",
    "test": "vitest",
    "test:unit": "vitest run __tests__/unit --reporter=verbose",
    "test:integration": "vitest run __tests__/integration --reporter=verbose",
    "test:e2e": "vitest run __tests__/e2e --reporter=verbose",
    "test:coverage": "vitest run --coverage --reporter=verbose",
    "test:watch": "vitest --watch",
    "test:fast": "vitest run __tests__/unit --reporter=basic --maxConcurrency=10",
    "test:ci": "vitest run --coverage --reporter=json --reporter=html --bail=1",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix"
  },
  "dependencies": {
    "@clerk/backend": "^2.21.0",
    "@hono/swagger-ui": "^0.5.1",
    "@hono/zod-validator": "^0.6.0",
    "cloudflare": "^4.4.1",
    "csv-parse": "^5.6.0",
    "drizzle-orm": "^0.36.4",
    "hono": "^4.7.10",
    "jsonwebtoken": "^9.0.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250813.0",
    "@eslint/js": "^9.39.1",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.10.2",
    "@typescript-eslint/eslint-plugin": "^8.15.0",
    "@typescript-eslint/parser": "^8.15.0",
    "@vitest/coverage-v8": "^2.1.8",
    "@vitest/ui": "2.1.9",
    "dotenv": "^16.5.0",
    "drizzle-kit": "^0.28.1",
    "eslint": "^9.15.0",
    "postgres": "^3.4.7",
    "prettier": "^3.4.2",
    "tsx": "^4.13.1",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8",
    "vitest-environment-miniflare": "^2.14.4",
    "wrangler": "^4.4.0"
  },
  "keywords": [
    "stock",
    "market",
    "api",
    "cloudflare",
    "workers",
    "hono",
    "typescript"
  ],
  "author": "NavTrend Team",
  "license": "MIT"
}
