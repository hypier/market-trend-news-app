# ============================================
# NavTrend API - 开发环境变量示例
# ============================================
# 复制此文件为 .dev.vars 并填入实际的配置值
# 请将 .dev.vars 添加到 .gitignore 中，不要提交敏感信息

# RapidAPI 配置
# 获取地址: https://rapidapi.com/hub
RAPIDAPI_KEY=your_rapidapi_key_here

# JWT 密钥
# 建议使用 openssl rand -base64 64 生成强密钥
JWT_SECRET=your_jwt_secret_here

# API 密钥
# 用于内部 API 认证的密钥
API_SECRET_KEY=your_api_secret_key_here

# Clerk 认证密钥
# 获取地址: https://dashboard.clerk.com/
# 开发环境使用 sk_test_ 开头的密钥，生产环境使用 sk_live_ 开头的密钥
CLERK_SECRET_KEY=your_clerk_secret_key_here
